---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Dinithi Jayasekara | Creative Strategist"
			description="Creative strategy, SEO content, and website messaging for brands that want clearer positioning, stronger structure, and better growth."
		/>
	</head>
	<body>
		<Header />

		<main class="home-page">
			<!-- HERO -->
			<section class="hero-v2">
			<div class="container hero-v2-grid">
				<div class="hero-v2-visual">
					<div class="hero-v2-main"></div>
					<div class="hero-v2-accent"></div>
					<div class="hero-v2-note">
						<p>Clearer messaging</p>
						<span>Strategy · Structure · SEO</span>
					</div>
				</div>

				<div class="hero-v2-copy">
					<p class="hero-v2-eyebrow">Creative strategy · SEO content · Website messaging</p>
					<h1 class="hero-v2-title">
						Helping brands connect with the right people.
					</h1>
					<p class="hero-v2-text">
						I help businesses shape their messaging, strengthen page structure, and build SEO-led content
						that feels human, commercially clear, and easier to trust.
					</p>

					<div class="hero-v2-actions">
						<a href="/portfolio" class="btn btn-primary">View portfolio</a>
						<a href="/contact" class="btn btn-secondary">Work with me</a>
					</div>
				</div>
			</div>
		</section>

			<!-- PROOF STRIP -->
			<section class="proof-strip">
				<div class="container">
					<p class="proof-label">Worked across industries including</p>
					<div class="proof-items">
						<span>Legal</span>
						<span>Digital Marketing</span>
						<span>Trades</span>
						<span>Finance</span>
						<span>Jewellery</span>
						<span>Tourism</span>
					</div>
				</div>
			</section>

			<!-- POSITIONING -->
			<section class="section">
				<div class="container split-section">
					<div class="split-copy">
						<p class="eyebrow">Why strategy matters</p>
						<h2>If your message is unclear, even strong businesses get overlooked.</h2>
						<p>
							A lot of websites say the right things loosely, but not clearly enough to move people.
							Content gets published, pages get filled, and blogs go live, but the structure underneath
							it all is weak.
						</p>
						<p>
							My work focuses on fixing that. I help businesses bring together positioning, page
							structure, search intent, and messaging so their websites feel more useful, more coherent,
							and easier to trust.
						</p>
						<a href="/about" class="text-link">About my approach</a>
					</div>

					<div class="split-visual">
						<div class="stack-card stack-card-1"></div>
						<div class="stack-card stack-card-2"></div>
						<div class="stack-card stack-card-3"></div>
					</div>
				</div>
			</section>

			<!-- TESTIMONIAL BAND -->
			<section class="testimonial-band">
				<div class="container testimonial-grid">
					<div>
						<p class="quote">
							“Strong messaging is not just about sounding better. It changes how people understand the
							value of what you do.”
						</p>
						<p class="quote-meta">A simple principle behind how I approach content and positioning</p>
					</div>
					<div class="quote-avatar"></div>
				</div>
			</section>

			<!-- FEATURED WORK -->
			<section class="section featured-work">
				<div class="container">
					<div class="section-heading">
						<p class="eyebrow">Selected work</p>
						<h2>Featured Work</h2>
					</div>

					<div class="work-grid">
	<a href="/portfolio" class="work-card featured">
		<div class="work-thumb thumb-1"></div>
		<h3>SEO Content Systems</h3>
		<p>Service pages, blogs, and content structures designed around search behaviour.</p>
	</a>

	<div class="work-side-stack">
		<a href="/portfolio" class="work-card">
			<div class="work-thumb thumb-2"></div>
			<h3>Website Copy & Restructuring</h3>
			<p>Clearer messaging, stronger hierarchy, and better user flow across core pages.</p>
		</a>

		<a href="/portfolio" class="work-card">
			<div class="work-thumb thumb-3"></div>
			<h3>Brand Messaging Support</h3>
			<p>Sharper language and positioning for brands that need more clarity and consistency.</p>
		</a>
	</div>

	<div class="work-bottom-grid">
		<a href="/portfolio" class="work-card">
			<div class="work-thumb thumb-4"></div>
			<h3>SEO-Led Content Planning</h3>
			<p>Content mapped to audience intent, commercial goals, and long-term visibility.</p>
		</a>

		<a href="/portfolio" class="work-card">
			<div class="work-thumb thumb-5"></div>
			<h3>Local Service Content</h3>
			<p>Location-driven pages built to support local search while still sounding human.</p>
		</a>

		<a href="/portfolio" class="work-card">
			<div class="work-thumb thumb-6"></div>
			<h3>Content Strategy for Growth</h3>
			<p>Structured thinking for brands that want content to support growth, not just output.</p>
		</a>
	</div>
</div>

					<div class="center-cta">
						<a href="/portfolio" class="btn btn-secondary">See full portfolio</a>
					</div>
				</div>
			</section>

			<!-- SERVICES BAND -->
			<section class="services-band">
				<div class="container">
					<div class="section-heading centered light">
						<p class="eyebrow">How we can work together</p>
						<h2>What I can help with</h2>
					</div>

					<div class="services-grid">
						<div class="service-box">
							<h3>SEO Content</h3>
							<p>Blogs, service pages, and content systems built around search intent and structure.</p>
						</div>
						<div class="service-box">
							<h3>Website Copy</h3>
							<p>Clearer web messaging that helps brands explain what they do and why it matters.</p>
						</div>
						<div class="service-box">
							<h3>Content Strategy</h3>
							<p>Content planning grounded in user behaviour, positioning, and commercial goals.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- ABOUT SECTION -->
			<section class="section about-section">
				<div class="container about-grid">
					<div class="about-photo"></div>

					<div class="about-copy">
						<p class="eyebrow">About</p>
						<h2>Hi, I’m Dinithi — I help brands turn ideas, services, and strategy into clearer communication.</h2>
						<p>
							My work sits at the intersection of messaging, SEO, structure, and user understanding.
							I’m especially interested in how content can support not just rankings, but trust,
							decision-making, and growth.
						</p>
						<p>
							I’ve worked across legal, digital marketing, service-based businesses, finance,
							jewellery, and tourism, helping brands sound more intentional and commercially aligned.
						</p>
						<a href="/about" class="btn btn-primary">More about me</a>
					</div>
				</div>
			</section>

			<!-- FINAL CTA -->
			<section class="final-cta">
				<div class="container final-cta-inner">
					<p class="eyebrow">Ready to refine your message?</p>
					<h2>Let’s build a website and content system that feels clearer, stronger, and easier to trust.</h2>
					<p>
						If your brand has outgrown generic content and unclear page messaging, I can help you make it
						feel more strategic and more useful.
					</p>
					<a href="/contact" class="btn btn-primary">Get in touch</a>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	:root {
		--bg: #f7f3ee;
		--surface: #fcfaf7;
		--text: #2b2a28;
		--muted: #6d675f;
		--sage: #8fa08c;
		--olive: #5f6f5d;
		--clay: #c8a58d;
		--gold: #b5964d;
		--border: #ddd3c8;
	}

	body {
		background: var(--bg);
		color: var(--text);
	}

	.home-page {
		background: var(--bg);
	}

	.container {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section {
		padding: 7.5rem 0;
	}

	.eyebrow {
		font-size: 0.85rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 1rem;
	}

	h2,
	h3 {
		font-weight: 500;
		color: var(--text);
		}

	h1 {
		font-size: clamp(2.8rem, 4.8vw, 4.8rem);
		line-height: 1.02;
		margin: 0 0 1.2rem;
		max-width: 9.5ch;
	}

	h2 {
		font-size: clamp(2.2rem, 4vw, 3.5rem);
		line-height: 1.02;
		margin: 0 0 1.2rem;
		max-width: 13ch;
		letter-spacing: -0.02em; 
	}

	h3 {
		font-size: 1.15rem;
		line-height: 1.25;
		margin: 0 0 0.7rem;
		letter-spacing: -0.03em;
	}

	p {
		font-size: 1rem;
		line-height: 1.75;
		color: var(--muted);
		margin: 0 0 1rem;
		max-width: 58ch;
	}

	
.split-section {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4.5rem;
	align-items: start;
}

.about-grid {
	display: grid;
	grid-template-columns: 0.95fr 1.05fr;
	gap: 4.5rem;
	align-items: start;
}

.about-photo {
	grid-column: 1;
	justify-self: start;
	width: 100%;
	max-width: 520px;
	min-height: 300px;
	background: linear-gradient(135deg, #d8c1ab, #f1e8de);
	box-shadow:
		0 24px 48px rgba(43, 42, 40, 0.06),
		0 4px 12px rgba(43, 42, 40, 0.03);
	position: relative;
}

.about-photo::after {
	content: "";
	position: absolute;
	width: 80%;
	height: 70%;
	right: -30px;
	bottom: -30px;
	background: var(--bg);
	z-index: -1;
}

.about-copy {
	grid-column: 2;
	max-width: 560px;
	padding-top: 1.5rem;
}

	

.split-copy {
	max-width: 560px;
}

.split-visual {
	justify-self: end;
	width: 100%;
	max-width: 560px;
}


	.visual-card {
		background: var(--surface);
		border: 1px solid var(--border);
		padding: 1rem;
		height: 100%;
		display: grid;
		grid-template-rows: 1.8fr 0.7fr 1fr;
		gap: 1rem;
		box-shadow: 0 16px 40px rgba(43, 42, 40, 0.05);
	}

	.visual-block {
		border-radius: 2px;
	}

	.image-block {
		background: linear-gradient(135deg, #bfa48c, #e7d9ca);
		box-shadow: inset 0 0 0 1px rgba(0,0,0,0.05);
	}

	.small-block {
		background: #eee4d9;
		width: 55%;
	}

	.medium-block {
		background: linear-gradient(135deg, #d7d1c7, var(--sage));
	}

	.button-row {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.btn {
		display: inline-flex;
	align-items: center;
	justify-content: center;
	padding: 0.75rem 1.1rem;
	text-decoration: none;
	font-size: 0.82rem;
	transition: 0.2s ease;
	border: 1px solid transparent;
	}

	.btn-primary {
		background: var(--text);
		color: white;
		border-radius: 2px;
	}

	.btn-primary:hover {
		background: #1f1e1c;
		transform: translateY(-1px);
	}

	.btn-secondary {
		background: transparent;
		color: var(--text);
		border-color: var(--text);
	}

	.btn-secondary:hover {
		background: rgba(43, 42, 40, 0.05);
	}

	.text-link {
		display: inline-block;
		margin-top: 1rem;
		color: var(--text);
		text-decoration: underline;
		text-underline-offset: 0.18em;
	}

	.proof-strip {
		padding: 2.2rem 0;
		background: var(--surface);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}

	.proof-label {
		text-align: center;
		margin-bottom: 1rem;
		font-size: 0.9rem;
	}

	.proof-items {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1.8rem;
		color: var(--text);
		font-size: 0.95rem;
	}

	.split-visual {
		position: relative;
		min-height: 420px;
	}

	.stack-card {
		position: absolute;
		border: 1px solid var(--border);
		background: var(--surface);
		box-shadow: 0 16px 34px rgba(43, 42, 40, 0.06);
	}

	.stack-card-1 {
		width: 58%;
		height: 280px;
		top: 0;
		right: 8%;
		background: linear-gradient(135deg, #c09a7d, #eaded0);
	}

	.stack-card-2 {
		width: 44%;
		height: 160px;
		bottom: 10%;
		left: 6%;
		background: linear-gradient(135deg, #ece4db, #d7ccc0);
	}

	.stack-card-3 {
		width: 42%;
		height: 180px;
		bottom: 0;
		right: 12%;
		background: linear-gradient(135deg, #cfd8d0, var(--sage));
	}

	.testimonial-band {
		padding: 4rem 0;
		background: var(--sage);
		position: relative;
		overflow: hidden;
	}

	.testimonial-grid {
		display: grid;
		grid-template-columns: 1.3fr 180px;
		gap: 2rem;
		align-items: center;
	}

	.quote {
		font-size: 1.5rem;
		line-height: 1.5;
		color: white;
		max-width: 36ch;
	}

	.quote-meta {
		color: rgba(255, 255, 255, 0.82);
		font-size: 0.95rem;
	}

	.quote-avatar {
		width: 170px;
		height: 170px;
		border-radius: 999px;
		background: linear-gradient(135deg, #f0e5d9, #c8a58d);
		border: 4px solid rgba(255, 255, 255, 0.7);
		justify-self: end;
	}

	.section-heading {
		margin-bottom: 2.5rem;
	}

	.section-heading.centered {
		text-align: center;
	}

	.section-heading.centered h2,
	.section-heading.centered p {
		margin-left: auto;
		margin-right: auto;
	}

	.section-heading.light .eyebrow,
	.section-heading.light h2 {
		color: white;
		max-width: none;
	}

	.section-title {
		font-size: 1.9rem;
		margin-top: 0.3rem;
	}

	.section-label {
		letter-spacing: 0.08em;
		font-size: 0.7rem;
		color: var(--muted);
	}

	.work-section {
		border-top: 1px solid var(--border);
		padding-top: 3.5rem;
	}

/*.work-grid {
		display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 2rem;
	margin-top: 2.4rem;
}

.work-card.featured {
	grid-column: 1 / span 2;
}

.work-card.featured .work-thumb {
	aspect-ratio: 16 / 9;
	min-height: 0;
	height: auto;
}

.work-card.featured h3 {
	font-size: 1rem;
}*/


/*.work-grid {
	display: grid;
	grid-template-columns: repeat(3, minmax(0, 1fr));
	gap: 2rem;
	margin-top: 2.25rem;
}*/

.work-grid {
	display: grid;
	grid-template-columns: 1.65fr 1fr;
	gap: 2rem;
	align-items: stretch;
}

.work-card.featured {
	height: 100%;
}

.work-side-stack {
	display: grid;
	grid-template-rows: 1fr 1fr;
	gap: 1.4rem;
	height: 100%;
}

.work-side-stack .work-card {
	height: 100%;
}

.work-bottom-grid {
	grid-column: 1 / -1;
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 2rem;
}



.work-card {
	display: flex;
	flex-direction: column;
	height: 100%;
	text-decoration: none;
	color: inherit;
}

.work-thumb {
	margin-bottom: 0.6rem;
}

.work-card h3 {
	margin-bottom: 1.02rem;
}

.work-card p {
	margin-top: auto; /* THIS fixes alignment */
	font-size: 0.84rem;
	line-height: 1.6;
	max-width: 28ch;
	min-height: 48px;
}

.work-thumb {
	width: 100%;
	min-height: 180px;
	aspect-ratio: 4 / 3;
	border-radius: 2px;
	box-shadow: 0 10px 26px rgba(43, 42, 40, 0.06);
	transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.work-card.featured .work-thumb {
	aspect-ratio: 16 / 9.5;
}

.work-card.featured h3 {
	font-size: 1rem;
	max-width: 20ch;
}

.work-card.featured p {
	max-width: 32ch;
}

.work-card:hover .work-thumb {
	transform: translateY(-4px);
	box-shadow: 0 18px 36px rgba(43, 42, 40, 0.1);
}

.work-card h3 {
	font-size: 1rem;
	margin: 0;
	font-weight: bold;
	line-height: 1.3;
	max-width: 22ch;
}

.work-card:hover h3 {
	text-decoration: underline;
	text-underline-offset: 0.2em;
}

.work-card p {
	font-size: 0.8rem;
	line-height: 1.55;
	color: #5d5d5d;
	margin: 0;
	max-width: 30ch;
}

.thumb-1 { background: linear-gradient(135deg, #8b6b57, #e7d7c8); }
.thumb-2 { background: linear-gradient(135deg, #d9dfd7, #b9c7b7); }
.thumb-3 { background: linear-gradient(135deg, #f1e3b2, #d8c15f); }
.thumb-4 { background: linear-gradient(135deg, #eadfd3, #d3c2b6); }
.thumb-5 { background: linear-gradient(135deg, #e8d8c6, #f8f3ec); }
.thumb-6 { background: linear-gradient(135deg, #dad6cf, #c2cabe); }

@media (max-width: 980px) {
	.work-grid {
		grid-template-columns: 1fr;
	}

	.work-bottom-grid {
		grid-template-columns: 1fr 1fr;
	}
}

@media (max-width: 720px) {
	.work-bottom-grid {
		grid-template-columns: 1fr;
	}
}


	.center-cta {
		text-align: center;
		margin-top: 2.5rem;
	}

	.services-band {
		padding: 5.5rem 0;
		background: var(--olive);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.service-box {
	padding: 2rem 1.2rem 1.8rem;
	border-top: 1px solid rgba(255, 255, 255, 0.28);
	border-bottom: 1px solid rgba(255, 255, 255, 0.18);
	min-height: 170px;
}

.service-box h3 {
	font-size: 1rem;
	margin-bottom: 0.6rem;
}

.service-box p {
	font-size: 0.88rem;
	line-height: 1.6;
	max-width: 28ch;
}



	.featured-work {
		padding-top: 6rem;
		padding-bottom: 6rem;
	}

	.featured-work .section-heading {
	margin-bottom: 2rem;
	}

	.final-cta {
	padding: 7rem 0;
	background: var(--surface);
	border-top: 1px solid var(--border);
	}

	.final-cta-inner {
		max-width: 720px;
		text-align: center;
		margin: 0 auto;
		
	}

	.final-cta-inner h2,
	.final-cta-inner p {
		margin-left: auto;
		margin-right: auto;
	}

	@media (max-width: 980px) {
	
	.split-section,
	.about-grid,
	.testimonial-grid {
		grid-template-columns: 1fr;
	}

	
	.split-copy,
	.about-copy {
		padding-right: 0;
		max-width: none;
	}

	.about-grid {
		grid-template-columns: 1fr;
	}

	.about-photo,
	.about-copy {
		grid-column: auto;
	}

	.about-photo,
	.split-visual {
		justify-self: start;
	}

	.work-grid {
		grid-template-columns: 1fr 1fr;
		grid-template-areas:
			"featured featured"
			"side1 side2"
			"bottom1 bottom2"
			"bottom3 bottom3";
	}
	
	.services-grid {
		grid-template-columns: 1fr 1fr;
	}

	.quote-avatar {
		justify-self: start;
	}
}

	@media (max-width: 720px) {
		.section {
			padding: 4.5rem 0;
		}

		
		.services-grid {
			grid-template-columns: 1fr;
		}

		.work-grid {
		grid-template-columns: 1fr;
	}

		h1 {
			max-width: none;
		}
	}

/* hero v2 */

.hero-v2 {
	/*padding: 4.5rem 0 3.5rem;*/
	/*border-bottom: 1px solid #e8e1d8;*/
	padding: 3.5rem 0 3.5rem; /* Reduced height */
	min-height: 70vh; /* Ensures it's not taller than the screen */
	display: flex;
	flex-direction: column;
	justify-content: center;
}

.hero-v2-grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4.5rem;
	align-items: center;
}

.hero-v2-visual {
	position: relative;
	height: 460px;
}

.hero-v2-main {
	width: 100%;
	max-width: 440px;
	height: 400px;
	background: linear-gradient(135deg, #ccb09a, #ecdccf);
	border: 1px solid var(--border);
	box-shadow: 0 20px 44px rgba(43, 42, 40, 0.08);
}

.hero-v2-accent {
	position:absolute;
	left: 8px;
	bottom: 18px;
	width: 86px;
	height: 68px;
	background: linear-gradient(135deg, #d9ddd5, #b8c5b5);
	border: 1px solid var(--border);
	box-shadow: 0 10px 24px rgba(43, 42, 40, 0.05);
}

.hero-v2-note {
	position: absolute;
	left: 110px;
	bottom: 34px;
	background: var(--surface);
	border: 1px solid var(--border);
	padding: 0.85rem 1rem;
	min-width: 185px;
	box-shadow: 0 14px 30px rgba(43, 42, 40, 0.06);
