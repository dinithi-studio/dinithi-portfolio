---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Dinithi Jayasekara | Creative Strategist"
			description="Creative strategy, SEO content, and website messaging for brands that want clearer positioning, stronger structure, and better growth."
		/>
	</head>
	<body>
		<Header />

		<main class="home-page">
			<!-- HERO -->
			<section class="hero-v2">
			<div class="container hero-v2-grid">
				<div class="hero-v2-visual">
					<div class="hero-v2-main"></div>
					<div class="hero-v2-accent"></div>
					<div class="hero-v2-note">
						<p>Clearer messaging</p>
						<span>Strategy · Structure · SEO</span>
					</div>
				</div>

				<div class="hero-v2-copy">
					<p class="hero-v2-eyebrow">Creative strategy · SEO content · Website messaging</p>
					<h1 class="hero-v2-title">
						Helping brands connect with the right people.
					</h1>
					<p class="hero-v2-text">
						I help businesses shape their messaging, strengthen page structure, and build SEO-led content
						that feels human, commercially clear, and easier to trust.
					</p>

					<div class="hero-v2-actions">
						<a href="/portfolio" class="btn btn-primary">View portfolio</a>
						<a href="/contact" class="btn btn-secondary">Work with me</a>
					</div>
				</div>
			</div>
		</section>

			<!-- PROOF STRIP -->
			<section class="proof-strip">
				<div class="container">
					<p class="proof-label">Worked across industries including</p>
					<div class="proof-items">
						<span>Legal</span>
						<span>Digital Marketing</span>
						<span>Trades</span>
						<span>Finance</span>
						<span>Jewellery</span>
						<span>Tourism</span>
					</div>
				</div>
			</section>

			<!-- POSITIONING -->
			<section class="section">
				<div class="container split-section">
					<div class="split-copy">
						<p class="eyebrow">Why strategy matters</p>
						<h2>If your message is unclear, even strong businesses get overlooked.</h2>
						<p>
							A lot of websites say the right things loosely, but not clearly enough to move people.
							Content gets published, pages get filled, and blogs go live, but the structure underneath
							it all is weak.
						</p>
						<p>
							My work focuses on fixing that. I help businesses bring together positioning, page
							structure, search intent, and messaging so their websites feel more useful, more coherent,
							and easier to trust.
						</p>
						<a href="/about" class="text-link">About my approach</a>
					</div>

					<div class="split-visual">
						<div class="stack-card stack-card-1"></div>
						<div class="stack-card stack-card-2"></div>
						<div class="stack-card stack-card-3"></div>
					</div>
				</div>
			</section>

			<!-- TESTIMONIAL BAND -->
			<section class="testimonial-band">
				<div class="container testimonial-grid">
					<div>
						<p class="quote">
							“Strong messaging is not just about sounding better. It changes how people understand the
							value of what you do.”
						</p>
						<p class="quote-meta">A simple principle behind how I approach content and positioning</p>
					</div>
					<div class="quote-avatar"></div>
				</div>
			</section>

			<!-- FEATURED WORK -->
			<section class="section featured-work">
				<div class="container">
					<div class="section-heading">
						<p class="eyebrow">Selected work</p>
						<h2>Featured Work</h2>
					</div>

					<div class="case-grid">
						<a href="/portfolio/onchain-case-study" class="case-card case-card-1">
							<div class="case-card-inner">
								<div class="case-card-face case-card-default">
									<p>
										Brand Positioning
									</p>
								</div>
								<div class="case-card-face case-card-hover">
									<p>Repositioned a crypto accounting firm into a focused B2B brand</p>
									<span class="case-card-cta">View Case Study</span>
								</div>
							</div>
						</a>

						<a href="/portfolio/at-digital-case-study" class="case-card case-card-2">
							<div class="case-card-inner">
								<div class="case-card-face case-card-default">
									<p>
										Webcopy Messaging Strategy
									</p>
								</div>
								<div class="case-card-face case-card-hover">
									<p>Refined service page messaging to improve clarity, structure, and conversion</p>
									<span class="case-card-cta">View Case Study</span>
								</div>
							</div>
						</a>

						<a href="/portfolio/legal-content-strategy-case-study" class="case-card case-card-3">
							<div class="case-card-inner">
								<div class="case-card-face case-card-default">
									<p>
										SEO Content Strategy
									</p>
								</div>
								<div class="case-card-face case-card-hover">
									<p>Built a structured content system targeting high-intent legal search queries</p>
									<span class="case-card-cta">View Case Study</span>
								</div>
							</div>
						</a>

						<a href="/portfolio/legal-service-page-case-study" class="case-card case-card-4">
							<div class="case-card-inner">
								<div class="case-card-face case-card-default">
									<p>
										Conversion-Focused Content
									</p>
								</div>
								<div class="case-card-face case-card-hover">
									<p>Created a high-intent service page designed to convert search traffic into enquiries</p>
									<span class="case-card-cta">View Case Study</span>
								</div>
							</div>
						</a>
					</div>
					<div class="featured-work-actions">
						<a href="/portfolio" class="btn btn-primary">View portfolio</a>
						<a href="/contact" class="btn btn-secondary">Work with me</a>
					</div>
				</div>
			</section>

			<!-- SERVICES BAND -->
			<section class="services-band">
				<div class="container">
					<div class="section-heading centered light">
						<p class="eyebrow">How we can work together</p>
						<h2>What I can help with</h2>
					</div>

					<div class="services-grid">
						<div class="service-box">
							<h3>SEO Content</h3>
							<p>Blogs, service pages, and content systems built around search intent and structure.</p>
						</div>
						<div class="service-box">
							<h3>Website Copy</h3>
							<p>Clearer web messaging that helps brands explain what they do and why it matters.</p>
						</div>
						<div class="service-box">
							<h3>Content Strategy</h3>
							<p>Content planning grounded in user behaviour, positioning, and commercial goals.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- ABOUT SECTION -->
			<section class="section about-section">
				<div class="container about-grid">
					<div class="about-photo"></div>

					<div class="about-copy">
						<p class="eyebrow">About</p>
						<h2>Hi, I’m Dinithi — I help brands turn ideas, services, and strategy into clearer communication.</h2>
						<p>
							My work sits at the intersection of messaging, SEO, structure, and user understanding.
							I’m especially interested in how content can support not just rankings, but trust,
							decision-making, and growth.
						</p>
						<p>
							I’ve worked across legal, digital marketing, service-based businesses, finance,
							jewellery, and tourism, helping brands sound more intentional and commercially aligned.
						</p>
						<a href="/about" class="btn btn-primary">More about me</a>
					</div>
				</div>
			</section>

			<!-- FINAL CTA -->
			<section class="final-cta">
				<div class="container final-cta-inner">
					<p class="eyebrow">Ready to refine your message?</p>
					<h2>Let’s build a website and content system that feels clearer, stronger, and easier to trust.</h2>
					<p>
						If your brand has outgrown generic content and unclear page messaging, I can help you make it
						feel more strategic and more useful.
					</p>
					<a href="/contact" class="btn btn-primary">Get in touch</a>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	:root {
		--bg: #f7f3ee;
		--surface: #fcfaf7;
		--text: #2b2a28;
		--muted: #6d675f;
		--sage: #8fa08c;
		--olive: #5f6f5d;
		--clay: #c8a58d;
		--gold: #b5964d;
		--border: #ddd3c8;
	}

	body {
		background: var(--bg);
		color: var(--text);
	}

	.home-page {
		background: var(--bg);
	}

	.container {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section {
		padding: 7.5rem 0;
	}

	.eyebrow {
		font-size: 0.85rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 1rem;
	}

	h2,
	h3 {
		font-weight: 500;
		color: var(--text);
		}

	h1 {
		font-size: clamp(2.8rem, 4.8vw, 4.8rem);
		line-height: 1.02;
		margin: 0 0 1.2rem;
		max-width: 9.5ch;
	}

	h2 {
		font-size: clamp(2.2rem, 4vw, 3.5rem);
		line-height: 1.02;
		margin: 0 0 1.2rem;
		max-width: 13ch;
		letter-spacing: -0.02em; 
	}

	h3 {
		font-size: 1.15rem;
		line-height: 1.25;
		margin: 0 0 0.7rem;
		letter-spacing: -0.03em;
	}

	p {
		font-size: 1rem;
		line-height: 1.75;
		color: var(--muted);
		margin: 0 0 1rem;
		max-width: 58ch;
	}

	
.split-section {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4.5rem;
	align-items: start;
}

.about-grid {
	display: grid;
	grid-template-columns: 0.95fr 1.05fr;
	gap: 4.5rem;
	align-items: start;
}

.about-photo {
	grid-column: 1;
	justify-self: start;
	width: 100%;
	max-width: 520px;
	min-height: 300px;
	background: linear-gradient(135deg, #d8c1ab, #f1e8de);
	box-shadow:
		0 24px 48px rgba(43, 42, 40, 0.06),
		0 4px 12px rgba(43, 42, 40, 0.03);
	position: relative;
}

.about-photo::after {
	content: "";
	position: absolute;
	width: 80%;
	height: 70%;
	right: -30px;
	bottom: -30px;
	background: var(--bg);
	z-index: -1;
}

.about-copy {
	grid-column: 2;
	max-width: 560px;
	padding-top: 1.5rem;
}

	

.split-copy {
	max-width: 560px;
}

.split-visual {
	justify-self: end;
	width: 100%;
	max-width: 560px;
}


	.visual-card {
		background: var(--surface);
		border: 1px solid var(--border);
		padding: 1rem;
		height: 100%;
		display: grid;
		grid-template-rows: 1.8fr 0.7fr 1fr;
		gap: 1rem;
		box-shadow: 0 16px 40px rgba(43, 42, 40, 0.05);
	}

	.visual-block {
		border-radius: 2px;
	}

	.image-block {
		background: linear-gradient(135deg, #bfa48c, #e7d9ca);
		box-shadow: inset 0 0 0 1px rgba(0,0,0,0.05);
	}

	.small-block {
		background: #eee4d9;
		width: 55%;
	}

	.medium-block {
		background: linear-gradient(135deg, #d7d1c7, var(--sage));
	}

	.button-row {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.btn {
		display: inline-flex;
	align-items: center;
	justify-content: center;
	padding: 0.75rem 1.1rem;
	text-decoration: none;
	font-size: 0.82rem;
	transition: 0.2s ease;
	border: 1px solid transparent;
	}

	.btn-primary {
		background: var(--text);
		color: white;
		border-radius: 2px;
	}

	.btn-primary:hover {
		background: #1f1e1c;
		transform: translateY(-1px);
	}

	.btn-secondary {
		background: transparent;
		color: var(--text);
		border-color: var(--text);
	}

	.btn-secondary:hover {
		background: rgba(43, 42, 40, 0.05);
	}

	.text-link {
		display: inline-block;
		margin-top: 1rem;
		color: var(--text);
		text-decoration: underline;
		text-underline-offset: 0.18em;
	}

	.proof-strip {
		padding: 2.2rem 0;
		background: var(--surface);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}

	.proof-label {
		text-align: center;
		margin-bottom: 1rem;
		font-size: 0.9rem;
	}

	.proof-items {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1.8rem;
		color: var(--text);
		font-size: 0.95rem;
	}

	.split-visual {
		position: relative;
		min-height: 420px;
	}

	.stack-card {
		position: absolute;
		border: 1px solid var(--border);
		background: var(--surface);
		box-shadow: 0 16px 34px rgba(43, 42, 40, 0.06);
	}

	.stack-card-1 {
		width: 58%;
		height: 280px;
		top: 0;
		right: 8%;
		background: linear-gradient(135deg, #c09a7d, #eaded0);
	}

	.stack-card-2 {
		width: 44%;
		height: 160px;
		bottom: 10%;
		left: 6%;
		background: linear-gradient(135deg, #ece4db, #d7ccc0);
	}

	.stack-card-3 {
		width: 42%;
		height: 180px;
		bottom: 0;
		right: 12%;
		background: linear-gradient(135deg, #cfd8d0, var(--sage));
	}

	.testimonial-band {
		padding: 4rem 0;
		background: var(--sage);
		position: relative;
		overflow: hidden;
	}

	.testimonial-grid {
		display: grid;
		grid-template-columns: 1.3fr 180px;
		gap: 2rem;
		align-items: center;
	}

	.quote {
		font-size: 1.5rem;
		line-height: 1.5;
		color: white;
		max-width: 36ch;
	}

	.quote-meta {
		color: rgba(255, 255, 255, 0.82);
		font-size: 0.95rem;
	}

	.quote-avatar {
		width: 170px;
		height: 170px;
		border-radius: 999px;
		background: linear-gradient(135deg, #f0e5d9, #c8a58d);
		border: 4px solid rgba(255, 255, 255, 0.7);
		justify-self: end;
	}

	.section-heading {
		margin-bottom: 2rem;
	}

	.section-heading.centered {
		text-align: center;
	}

	.section-heading.centered h2,
	.section-heading.centered p {
		margin-left: auto;
		margin-right: auto;
	}

	.section-heading.light .eyebrow,
	.section-heading.light h2 {
		color: white;
		max-width: none;
	}

	.featured-work .section-heading h2 {
	font-size: clamp(2rem, 3.2vw, 3rem);
	max-width: none;
}

	.section-title {
		font-size: 1.9rem;
		margin-top: 0.3rem;
	}

	.section-label {
		letter-spacing: 0.08em;
		font-size: 0.7rem;
		color: var(--muted);
	}

	.work-section {
		border-top: 1px solid var(--border);
		padding-top: 3.5rem;
	}

.case-grid {
	display: grid;
	grid-template-columns: repeat(2, minmax(0, 1fr));
	gap: 1.75rem;
	margin-top: 2rem;
}

.case-card {
	display: flex;
	flex-direction: column;
	text-decoration: none;
	color: inherit;
	cursor: pointer;
}

.case-card-inner {
	position: relative;
	display: grid;
	place-items: center;
	min-height: 320px;
	padding: 1.75rem;
	overflow: hidden;
	box-shadow: 0 8px 20px rgba(43, 42, 40, 0.04);
	transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
}

.case-card-inner::before {
	content: "";
	position: absolute;
	inset: 14px;
	border: 1px solid rgba(255, 255, 255, 0.22);
	pointer-events: none;
}

.case-card-inner::after {
	content: "";
	position: absolute;
	inset: 0;
	background:
		linear-gradient(rgba(255,255,255,0.06), rgba(255,255,255,0)),
		radial-gradient(circle at top left, rgba(255,255,255,0.12), transparent 35%);
	pointer-events: none;
}

.case-card-1 .case-card-inner {
	background: linear-gradient(135deg, #b09079, #d4beac);
}

.case-card-2 .case-card-inner {
	background: linear-gradient(135deg, #d3dbd0, #bcc7bb);
}

.case-card-3 .case-card-inner {
	background: linear-gradient(135deg, #e6d284, #d5bf5d);
}

.case-card-4 .case-card-inner {
	background: linear-gradient(135deg, #dbd4cb, #c4cbc0);
}

.case-card-face {
	grid-area: 1 / 1;
	text-align: center;
	max-width: 22ch;
	transition: opacity 0.24s ease, transform 0.24s ease;
}

.case-card-default {
	opacity: 1;
	transform: translateY(0);
}

.case-card-hover {
	opacity: 0;
	transform: translateY(8px);
}

.case-card-default p {
	margin: 0;
	font-size: 1.45rem;
	line-height: 1.12;
	letter-spacing: -0.03em;
	color: var(--text);
	font-weight: 500;
	max-width: 11ch;
}

.case-card-hover p {
	margin: 0;
	font-size: 0.95rem;
	line-height: 1.45;
	color: var(--text);
	max-width: 22ch;
}

.case-card-cta {
	display: inline-block;
	margin-top: 1rem;
	font-size: 0.76rem;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	color: var(--text);
	border-bottom: 1px solid currentColor;
	padding-bottom: 0.12rem;
}

.case-card:hover .case-card-inner,
.case-card:focus-visible .case-card-inner {
	transform: translateY(-2px) scale(1.005);
	box-shadow: 0 16px 30px rgba(43, 42, 40, 0.08);
	filter: brightness(0.995);
}

.case-card:hover .case-card-default,
.case-card:focus-visible .case-card-default {
	opacity: 0;
	transform: translateY(-8px);
}

.case-card:hover .case-card-hover,
.case-card:focus-visible .case-card-hover {
	opacity: 1;
	transform: translateY(0);
}

.case-card:focus-visible {
	outline: none;
}

.case-card:focus-visible .case-card-inner {
	box-shadow:
		0 18px 36px rgba(43, 42, 40, 0.1),
		0 0 0 2px rgba(43, 42, 40, 0.18);
}

@media (max-width: 720px) {
	.case-grid {
		grid-template-columns: 1fr;
	}

	.case-card-inner {
		min-height: 280px;
	}

	.case-card-hover {
		display: none;
	}

	.case-card-default p {
		font-size: 1.2rem;
	}
}



.featured-work-actions {
	display: flex;
	justify-content: center;
	gap: 0.9rem;
	flex-wrap: wrap;
	margin-top: 2rem;
}







	.center-cta {
		text-align: center;
		margin-top: 2.5rem;
	}

	.services-band {
		padding: 5.5rem 0;
		background: var(--olive);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.5rem;
		margin-top: 2rem;
	}

.service-box {
	padding: 2rem 1.2rem 1.8rem;
	border-top: 1px solid rgba(255, 255, 255, 0.25);
	border-bottom: 1px solid rgba(255, 255, 255, 0.12);
	min-height: 170px;
	transition: opacity 0.25s ease, transform 0.25s ease;
}

.service-box:hover {
	transform: translateY(-2px);
	opacity: 0.95;
}

.service-box h3 {
	font-size: 1rem;
	margin-bottom: 0.6rem;
	color: #ffffff;
}

.service-box p {
	font-size: 0.88rem;
	line-height: 1.6;
	max-width: 28ch;
	color: rgba(255, 255, 255, 0.78); /* FIX */
}



	.featured-work {
		padding-top: 6.5rem;
		padding-bottom: 6.5rem;
	}

	.featured-work .section-heading {
	margin-bottom: 2rem;
	}

	.final-cta {
	padding: 7rem 0;
	background: var(--surface);
	border-top: 1px solid var(--border);
	}

	.final-cta-inner {
		max-width: 720px;
		text-align: center;
		margin: 0 auto;
		
	}

	.final-cta-inner h2,
	.final-cta-inner p {
		margin-left: auto;
		margin-right: auto;
	}

	@media (max-width: 980px) {
	
	.split-section,
	.about-grid,
	.testimonial-grid {
		grid-template-columns: 1fr;
	}

	
	.split-copy,
	.about-copy {
		padding-right: 0;
		max-width: none;
	}

	.about-grid {
		grid-template-columns: 1fr;
	}

	.about-photo,
	.about-copy {
		grid-column: auto;
	}

	.about-photo,
	.split-visual {
		justify-self: start;
	}

	
	
	.services-grid {
		grid-template-columns: 1fr 1fr;
	}

	.quote-avatar {
		justify-self: start;
	}
}

	@media (max-width: 720px) {
		.section {
			padding: 4.5rem 0;
		}

		
		.services-grid {
			grid-template-columns: 1fr;
		}

	

		h1 {
			max-width: none;
		}
	}

/* hero v2 */

.hero-v2 {
	/*padding: 4.5rem 0 3.5rem;*/
	/*border-bottom: 1px solid #e8e1d8;*/
	padding: 3.5rem 0 3.5rem; /* Reduced height */
	min-height: 70vh; /* Ensures it's not taller than the screen */
	display: flex;
	flex-direction: column;
	justify-content: center;
}

.hero-v2-grid {
