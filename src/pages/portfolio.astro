---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Portfolio | Dinithi Studio"
			description="Explore selected work across SEO content, website copy, and content strategy by Dinithi Studio."
		/>
	</head>
	<body>
		<Header />
		<main style="max-width: 1000px; margin: 0 auto; padding: 4rem 1.5rem;">
			<h1 style="font-size: 2.5rem; margin-bottom: 1rem;">Portfolio</h1>
			<p style="line-height: 1.8; margin-bottom: 2rem; max-width: 750px;">
				Selected work across SEO content, website copy, and content strategy.
			</p>

			<div style="display: grid; gap: 1.5rem;">
				<div style="border: 1px solid #ddd; padding: 1.25rem;">
					<h2 style="margin-bottom: 0.5rem;">SEO and service page content</h2>
					<p style="line-height: 1.7;">
						Built and refined service pages, landing pages, and blog content designed to support search visibility and conversion.
					</p>
				</div>

				<div style="border: 1px solid #ddd; padding: 1.25rem;">
					<h2 style="margin-bottom: 0.5rem;">Website messaging and restructuring</h2>
					<p style="line-height: 1.7;">
						Helped improve messaging clarity, content hierarchy, and user flow for websites across multiple industries.
					</p>
				</div>

				<div style="border: 1px solid #ddd; padding: 1.25rem;">
					<h2 style="margin-bottom: 0.5rem;">Content strategy and planning</h2>
					<p style="line-height: 1.7;">
						Planned content around audience intent, brand voice, service positioning, and long-term SEO goals.
					</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>